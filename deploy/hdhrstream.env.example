# HDHRStream configuration (installed to /etc/hdhrstream.env).
# Edit and run: sudo systemctl restart hdhrstream

# Required: your HDHomeRun's base URL.
HDHR_URL=http://192.168.1.10

# Listen address (host:port). Behind a VPN, plain HTTP is fine.
HDHR_LISTEN=:8080

# Default transcode profile: heavy, mobile, internet720, internet480, internet360, internet240.
HDHR_PROFILE=heavy

# Uncomment for verbose debugging (request logs, ffmpeg verbose, browser console trace).
# HDHR_DEBUG=1

# Optional: enable DVR recording playback by pointing at your RECORD engine.
# HDHR_DVR=http://192.168.1.140:65001

# HDHR_WORKDIR is set by the systemd unit (tmpfs at /run/hdhrstream); no need to set it here.
